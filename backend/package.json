{
  "name": "safesignal-backend",
  "version": "1.0.0",
  "description": "Backend API for SafeSignal civic technology platform",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --runInBand",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:init": "node src/database/init.js",
    "db:reset": "node src/database/reset.js",
    "db:seed": "node src/database/seed.js",
    "db:migrate:incident-public-visibility": "node src/database/migrations/add_incident_public_visibility.js",
    "db:migrate:witness-constellation": "node src/database/migrations/add_witness_constellation.js",
    "db:migrate:incident-lifecycle": "node src/database/migrations/add_incident_lifecycle_timestamps.js",
    "db:migrate:incident-idempotency": "node src/database/migrations/add_incident_idempotency.js",
    "db:migrate:incident-video": "node src/database/migrations/add_incident_video_url.js",
    "db:migrate:media-judgment": "node src/database/migrations/add_report_media_judgment.js",
    "db:migrate:incident-feed-media-disclosure": "node src/database/migrations/add_incident_feed_media_disclosure.js",
    "db:migrate:saved-areas": "node src/database/migrations/add_saved_areas.js"
  },
  "jest": {
    "testEnvironment": "node",
    "globalTeardown": "<rootDir>/tests/jest.teardown.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@faker-js/faker": "^10.4.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "axios": "^1.6.0",
    "bad-words": "^3.0.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.0.0",
    "firebase-admin": "^13.8.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^8.9.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg-promise": "^11.5.0",
    "socket.io": "^4.7.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
